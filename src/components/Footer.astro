        </a>
        <a
          href="https://x.com/blossomstudios"
          target="_blank"
          rel="noopener noreferrer"
          class="text-ink-faint hover:text-ink-muted transition-colors duration-200"
          aria-label="X (Twitter)"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
