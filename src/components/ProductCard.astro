---
interface Props {
  name: string;
  tagline: string;
  slug: string;
  platforms: string[];
}

const { name, tagline, slug, platforms } = Astro.props;

const platformLabels: Record<string, string> = {
  chrome: 'Chrome Extension',
  firefox: 'Firefox Add-on',
  web: 'Web App',
  macos: 'macOS App',
  ios: 'iOS App',
};
---

<a
  href={`/products/${slug}/`}
  class="group block p-6 rounded-2xl border border-border bg-surface hover:border-border-hover hover:bg-surface-raised transition-all duration-300 hover:shadow-sm"
>
  <div class="flex items-start gap-4">
    <div class="w-12 h-12 rounded-xl bg-accent-light flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform duration-300">
      <span class="text-xl font-bold text-accent">{name[0]}</span>
    </div>
    <div class="min-w-0">
      <h3 class="text-heading font-semibold text-ink group-hover:text-accent transition-colors duration-200">
        {name}
      </h3>
      <p class="text-small text-ink-muted mt-1 leading-relaxed">
        {tagline}
      </p>
      <div class="flex flex-wrap gap-2 mt-3">
        {platforms.map((p) => (
          <span class="inline-flex items-center gap-1 text-caption text-ink-faint">
            <span class="w-1 h-1 rounded-full bg-accent/40"></span>
            {platformLabels[p] || p}
          </span>
        ))}
      </div>
    </div>
  </div>
</a>
