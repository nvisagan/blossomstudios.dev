---
interface Props {
  tag: string;
  href?: string;
}

const { tag, href } = Astro.props;
const Element = href ? 'a' : 'span';
---

<Element
  href={href}
  class:list={[
    'inline-block px-2.5 py-0.5 rounded-md text-caption font-medium bg-surface-raised text-ink-muted',
    href && 'hover:bg-surface-overlay hover:text-ink transition-colors duration-200',
  ]}
>
  {tag}
</Element>
