---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import BlogPostCard from '../../../../components/BlogPostCard.astro';
import Pagination from '../../../../components/Pagination.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const allPosts = (await getCollection('blog'))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))];

  return allTags.flatMap((tag) => {
    const tagPosts = allPosts.filter((post) => post.data.tags.includes(tag));
    return paginate(tagPosts, {
      params: { tag },
      pageSize: 10,
    });
  });
}

const { tag } = Astro.params;
const { page } = Astro.props;
---

<BaseLayout
  title={`Posts tagged "${tag}"`}
  description={`All blog posts tagged with "${tag}" from Blossom Studios.`}
>
  <div class="mx-auto max-w-[1120px] px-6 pt-16 pb-24">
    <section class="pt-12 pb-8">
      <a
        href="/blog/"
        class="inline-flex items-center gap-1.5 text-small font-medium text-ink-muted hover:text-accent transition-colors duration-200 mb-4"
      >
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 4l-4 4 4 4" />
        </svg>
        All posts
      </a>
      <h1 class="text-display text-ink">
        Tagged <span class="text-accent">"{tag}"</span>
      </h1>
    </section>

    <div class="divide-y divide-border">
      {page.data.map((post: any) => (
        <BlogPostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          slug={post.id}
        />
      ))}
    </div>

    <Pagination
      prevUrl={page.url.prev}
      nextUrl={page.url.next}
      currentPage={page.currentPage}
      lastPage={page.lastPage}
    />
  </div>
</BaseLayout>
