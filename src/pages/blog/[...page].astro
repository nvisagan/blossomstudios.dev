---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import Pagination from '../../components/Pagination.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const posts = (await getCollection('blog'))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return paginate(posts, { pageSize: 10 });
}

const { page } = Astro.props;
---

<BaseLayout
  title="Blog"
  description="Updates, changelogs, and articles from Blossom Studios."
>
  <div class="mx-auto max-w-[1120px] px-6 pt-16 pb-24">
    <section class="pt-12 pb-8">
      <h1 class="text-display text-ink">Blog</h1>
      <p class="text-body text-ink-muted mt-3">Updates, changelogs, and articles.</p>
    </section>

    <div class="divide-y divide-border">
      {page.data.map((post: any) => (
        <BlogPostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          slug={post.id}
        />
      ))}
    </div>

    <Pagination
      prevUrl={page.url.prev}
      nextUrl={page.url.next}
      currentPage={page.currentPage}
      lastPage={page.lastPage}
    />
  </div>
</BaseLayout>
