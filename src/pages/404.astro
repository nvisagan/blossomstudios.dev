---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist."
>
  <div class="mx-auto max-w-[1120px] px-6 pt-16 pb-24">
    <div class="flex flex-col items-center justify-center min-h-[50vh] text-center">
      <span class="text-6xl font-bold text-ink-faint mb-4">404</span>
      <h1 class="text-title text-ink mb-2">Page not found</h1>
      <p class="text-body text-ink-muted mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-ink text-surface text-small font-medium hover:bg-ink/90 transition-colors duration-200"
      >
        Go home
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 8h8m-4-4 4 4-4 4" />
        </svg>
      </a>
    </div>
  </div>
</BaseLayout>
